# Backend Environment Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/stockmate

# Server Configuration
PORT=8080

# Admin Account Configuration
# NOTE: Change these in production! Use strong passwords.
ADMIN_EMAIL=admin@stockmate.local
ADMIN_PASSWORD=ChangeMe123!Admin

# CORS Configuration (comma-separated for multiple origins)
# Default: http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth Token Configuration
# Change this in production so bearer tokens cannot be forged.
AUTH_TOKEN_SECRET=change-this-long-random-secret
# AUTH_TOKEN_TTL_HOURS=24

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
# Optional aliases supported by the backend:
# SMTP_FROM=your-email@gmail.com
# SMTP_EMAIL=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional: Logging Configuration
# LOG_LEVEL=info
# LOG_FORMAT=json
